# Server Configuration
PORT=3000
GRAPHQL_PORT=3001
NODE_ENV=development
GRAPHQL_PLAYGROUND_ENABLED=true
GRAPHQL_INTROSPECTION_ENABLED=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3001

# CORS Configuration
# Development: comma-separated list of additional origins to allow
# Production: comma-separated list of allowed origins (REQUIRED)
CORS_ALLOWED_ORIGINS=https://stellar-lumenmint.com,https://app.stellar-lumenmint.com
CORS_ORIGIN_DEV=http://localhost:3001

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=300

# Database Configuration (Optional for future use)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_lumenmint

# JWT Configuration
# JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# Stellar/Soroban Configuration
#
# SOROBAN_RPC_URL — the JSON-RPC endpoint used for all Soroban contract calls.
# It is validated and normalized at startup:
#   - Must be a valid http(s) URL (malformed URLs are rejected early).
#   - In production it is REQUIRED and must be https (localhost is rejected).
#   - Trailing slashes are removed automatically.
# The endpoint is health-checked on boot; the URL in use is logged at startup.
#
# Testnet (default for local development):
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Mainnet (set STELLAR_NETWORK=mainnet as well):
#   SOROBAN_RPC_URL=https://mainnet.sorobanrpc.com
#
# STELLAR_NETWORK — testnet | mainnet (case-insensitive). Defaults to testnet.
STELLAR_NETWORK=TESTNET
COLLECTION_FACTORY_CONTRACT_ID=CB6UOYI5KLAXLBBALZITFMCR6LIDHW2BQFRB7VXMUWZ6Z2BFTG3UFPM4
TRANSACTION_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TRANSACTION_TIMEOUT_SECONDS=60
SOROBAN_RPC_MAX_RETRIES=3
SOROBAN_RPC_RETRY_DELAY_MS=1000
SOROBAN_RPC_RETRY_BACKOFF_MULTIPLIER=2
SOROBAN_RPC_RETRY_MAX_DELAY_MS=30000
# Optional server-side signer for state-changing Soroban transactions.
# STELLAR_OPERATOR_PUBLIC_KEY=G...
# STELLAR_OPERATOR_SECRET=S...
# SOROBAN_EVENT_CONTRACT_IDS=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Decentralized Storage Configuration
IPFS_PROVIDER=pinata
IPFS_GATEWAY_URL=https://ipfs.io/ipfs
IPFS_MAX_FILE_SIZE_BYTES=52428800
IPFS_RETRY_ATTEMPTS=2
IPFS_RETRY_BACKOFF_MS=250
IPFS_PINATA_JWT=
IPFS_WEB3STORAGE_TOKEN=
IPFS_NFTSTORAGE_TOKEN=

ARWEAVE_GATEWAY_URL=https://arweave.net
ARWEAVE_MAX_FILE_SIZE_BYTES=104857600
ARWEAVE_HOST=arweave.net
ARWEAVE_PORT=443
ARWEAVE_PROTOCOL=https
ARWEAVE_RETRY_ATTEMPTS=2
ARWEAVE_RETRY_BACKOFF_MS=350
ARWEAVE_WALLET_PATH=
ARWEAVE_WALLET_JWK=

STORAGE_FALLBACK_ENABLED=true

# Meilisearch Configuration
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev-search-key

# Marketplace Settlement Smart Contract
MARKETPLACE_SETTLEMENT_CONTRACT_ID=CB7QBOUQ3YRBOTGZ32RNKQIBGIBL4EQRIQUYV4KEMIDVJ5IRQV57IXSK
CONTRACT_TRANSACTION_TIMEOUT=60
ENABLE_ONCHAIN_SETTLEMENT=true